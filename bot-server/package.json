{
  "name": "bot-server",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "build": "tsc",
    "db:init": "tsx -e \"import { initDb } from './src/db'; initDb();\"",
    "create-bot": "tsx scripts/create-bot.ts",
    "edit-bot": "tsx scripts/edit-bot.ts",
    "delete-bot": "tsx scripts/delete-bot.ts",
    "list-bots": "tsx scripts/list-bots.ts"
  },
  "dependencies": {
    "@hono/node-server": "^1.19.11",
    "dotenv": "^16.4.0",
    "hono": "^4.0.0",
    "sql.js": "^1.11.0"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "tsx": "^4.7.0",
    "typescript": "^5.3.0"
  }
}
