{
  "name": "Sabbatic Dev Container",
  "image": "mcr.microsoft.com/devcontainers/ruby:3.4-bullseye",
  "features": {
    "ghcr.io/devcontainers/features/homebrew:1": {},
    "ghcr.io/opencodehq/devcontainer-features/opencode:1": {},
    "ghcr.io/devcontainers/features/docker-in-docker:2": {},
    "ghcr.io/devcontainers/features/node:1": {},
    "ghcr.io/devcontainers/features/gum:1": {},
    "ghcr.io/devcontainers/features/mise:1": {}
  },
  "postCreateCommand": "brew install sqlite ffmpeg && bundle install && yarn install || true",
  "customizations": {
    "vscode": {
      "settings": {
        "terminal.integrated.defaultProfile.linux": "bash"
      },
      "extensions": [
        "rebornix.Ruby",
        "castwide.solargraph",
        "ms-azuretools.vscode-docker",
        "esbenp.prettier-vscode"
      ]
    }
  },
  "forwardPorts": [80, 443, 3000, 6379],
  "remoteUser": "vscode"
}
